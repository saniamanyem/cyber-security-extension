@prefix : <http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix d3f: <http://d3fend.mitre.org/ontologies/d3fend.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix s223: <http://data.ashrae.org/standard223#> .
@base <http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/> .g

<http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension> rdf:type owl:Ontology ;
                                                                     owl:imports <http://d3fend.mitre.org/ontologies/d3fend/1.4.0/d3fend.owl> ,
                                                                                 <http://data.ashrae.org/standard223/1.0/model/all> .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/ns/shacl#class
sh:class rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#path
sh:path rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#property
sh:property rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#targetClass
sh:targetClass rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################


d3f:AuthenticationServer rdfs:subclassOf :Asset ;
:hosts d3f:AuthenticationService ;
rdfs:label "d3f:AuthenticationServer" .

d3f:AuthenticationService rdfs:subclassOf d3f:Action ;
rdfs:label "d3f:AuthenticationService" ;
:validates d3f:Credential .


###  http://d3fend.mitre.org/ontologies/d3fend.owl#Database
d3f:Database rdfs:subClassOf :Asset ;
rdfs:label "d3f:Database" .

###  http://data.ashrae.org/standard223#Equipment
s223:Equipment rdfs:subClassOf :Asset ;
rdfs:label "s223:Equipment" .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/Asset
:Asset rdf:type owl:Class ;
rdfs:label ":Asset" .

###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/Condition
:Condition rdf:type owl:Class ;
rdfs:label ":Condition" .

:EmergencyCondition rdf:type :Condition ; 
  rdfs:label ":EmergencyCondition" . 

:MaintenanceWindow rdf:type :Condition ;
  rdfs:label ":MaintenanceWindow" . 

:NormalOperations rdf:type :Condition ;
  rdfs:label ":NormalOperations" .

###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/EnforcementPoint
:EnforcementPoint rdf:type owl:Class ;
rdfs:subclassOf :Asset ;
rdfs:label ":EnforcementPoint " .

:AuditLog rdf:type owl:Class ;
rdfs:subclassOf :Asset ;
rdfs:label ":AuditLog" .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/Permission
:Permission rdf:type s223:EnumerationKind ;
rdfs:label ":Permission" .

:OverrideDoorLocks rdf:type :Permission ;
rdfs:label ":OverrideDoorLocks " ;
:validDuring :EmergencyCondition .

:ViewCameraFeeds rdf:type :Permission ;
rdfs:label ":ViewCameraFeeds " .

:ModifySetpoints rdf:type :Permission ;
rdfs:label ":ModifySetpoints " .

:ControlAlarms rdf:type :Permission ;
rdfs:label ":ControlAlarms " .

:ConfigureControllers rdf:type :Permission ;
rdfs:label ":ConfigureControllers " .

:MonitorBuildingServer rdf:type :Permission ;
rdfs:label ":MonitorBuildingServer " .

:ViewSensorData rdf:type :Permission ;
rdfs:label ":ViewSensorData " .

:ApplySoftwareUpdates rdf:type :Permission ;
rdfs:label ":ApplySoftwareUpdates " .

:ModifyAccountDetails rdf:type :Permission ;
rdfs:label ":ModifyAccountDetails " .

:EmergencyOverride rdf:type :Permission ;
rdfs:label ":EmergencyOverride " ;
:validDuring :EmergencyCondition .

:ViewLogs rdf:type :Permission ;
rdfs:label ":ViewLogs " .


:EmergencyResponder rdf:type owl:Class ;
                    rdfs:subclassOf d3f:User ;
                    rdfs:label ":EmergencyResponder" .

:Vendor rdf:type owl:Class ;
                    rdfs:subclassOf d3f:User ;
                    rdfs:label ":Vendor" .

:Operator rdf:type owl:Class ;
                    rdfs:subclassOf d3f:User ;
                    rdfs:label ":Operator" .


:NetworkSegment rdf:type owl:Class ;
                rdfs:subClassOf d3f:Network ;
                rdfs:label ":NetworkSegment" .

:Device rdf:type owl:Class ;
        rdfs:subclassOf :Equipment ;
        rdfs:label ":Device" .

:AccessRequest rdf:type owl:Class ;
rdfs:label ":AccessRequest" .

:Event rdf:type owl:Class ; 
rdfs:label ":Event" . 

:ControlNetwork rdf:type :NetworkSegment ;
rdfs:label ":ControlNetwork" .

:RemoteAccessNetwork rdf:type :NetworkSegment , d3f:Network ;
rdfs:label "RemoteAccessNetwork" .

:DMZNetwork rdf:type :NetworkSegment ;
rdfs:label ":DMZNetwork" .

:EnterpriseNetwork rdf:type :NetworkSegment ;
rdfs:label ":EnterpriseNetwork" .

#################################################################
#    Individuals
#################################################################

:hosts rdf:type owl:NamedIndividual , s223:Relation ;
       rdfs:domain d3f:AuthenticationServer ;
       rdfs:range d3f:AuthenticationService ; 
       rdfs:label ":hosts" . 

:requestedBy rdf:type owl:NamedIndividual, s223:Relation ;
  rdfs:label ":requestedBy" ;
  rdfs:domain :AccessRequest ; 
  rdfs:range d3f:User . 

###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/affectedBy
:affectedBy rdf:type owl:NamedIndividual ,
                     s223:Relation ;
            rdfs:comment "A Permission is affected by a Condition" ;
            rdfs:label ":affectedBy" ;
            rdfs:domain :Asset ; 
            rdfs:range :Event .

###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/allowsAction
:allowsAction rdf:type owl:NamedIndividual ,
                       s223:Relation ;
              rdfs:label ":allowsAction" ;
              rdfs:domain :Permission ;
              rdfs:range d3f:Action . 

:recordsEvent rdf:type owl:NamedIndividual, s223:Relation ;
              rdfs:label ":recordsEvent" ;
              rdfs:domain :AuditLog ; 
              rdfs:range :Event .

:generatedBy rdf:type owl:NamedIndividual, s223:Relation ;
             rdfs:label ":generatedBy" ;
             rdfs:domain :Event ; 
             rdfs:range owl:Thing .

###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/appliesTo
:appliesTo rdf:type owl:NamedIndividual ,
                    s223:Relation ;
                    rdfs:label ":appliesTo" ;
                    rdfs:domain :Permission ; 
                    rdfs:range :Asset .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/enforcedBy
:enforcedBy rdf:type owl:NamedIndividual ,
                     s223:Relation ;
            rdfs:comment "A Permission is enforced by an Enforcement Point" ;
            rdfs:label "enforcedBy" ;
            rdfs:domain d3f:AuthenticationService ;
            rdfs:range :EnforcementPoint .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/hasCredential
:hasCredential rdf:type owl:NamedIndividual ,
                        s223:Relation ;
               rdfs:domain d3f:User ;
               rdfs:range d3f:Credential ;
               rdfs:comment "A User has credential Credential" ;
               rdfs:label ":hasCredential" .

:hasPermission rdf:type owl:NamedIndividual ,
                        s223:Relation ;
               rdfs:domain d3f:User ;
               rdfs:range :Permission ;
               rdfs:label ":hasPermission" .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/modifies
:modifies rdf:type owl:NamedIndividual ,
                   s223:Relation ;
                   rdfs:label ":modifies" ;
                   rdfs:domain d3f:Action ;
                   rdfs:range :Asset .

:protects rdf:type owl:NamedIndividual ,
                   s223:Relation ;
          rdfs:label ":protects" ;
          rdfs:domain :EnforcementPoint ;
          rdfs:range :Asset .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/requestsAccessTo
:requestsAccessTo rdf:type owl:NamedIndividual ,
                           s223:Relation ;
                  rdfs:domain :AccessRequest ;
                  rdfs:range: :Asset ;
                  rdfs:comment "A User requests access to an Asset" ;
                  rdfs:label ":requestsAccessTo" .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/validDuring
:validDuring rdf:type owl:NamedIndividual ,
                      s223:Relation ;
             rdfs:comment "A Permission is valid during a Condition" ;
             rdfs:label ":validDuring" ;
             rdfs:domain :Permission ; 
             rdfs:range :Condition .


:validates rdf:type owl:NamedIndividual ,
                   s223:Relation ;
                   rdfs:label ":validates" ;
                   rdfs:domain d3f:AuthenticationService ;
                   rdfs:range :Credential .


:containsAsset rdf:type owl:NamedIndividual ,
                      s223:Relation ;
              rdfs:comment "A network contains an asset" ;
              rdfs:label ":containsAsset" ;
              rdfs:domain d3f:Network ;
              rdfs:range :Device .

              
:usesDevice rdf:type owl:NamedIndividual ,
                      s223:Relation ;
              rdfs:comment "A User uses a Device" ;
              rdfs:label ":usesDevice" ;
              rdfs:domain d3f:User ;
              rdfs:range :Device .
            
:authorizedFor rdf:type owl:NamedIndividual ,
                        s223:Relation ;
                rdfs:label ":authorizedFor" ;
                rdfs:domain d3f:User ;
                rdfs:range :Permission .

d3f:User rdfs:label "d3f:User" .
d3f:Credential rdfs:label "d3f:Credential" .
d3f:Database rdfs:label "d3f:Database" .
d3f:AuthenticationService rdfs:label "d3f:AuthenticationService" .
d3f:Network rdfs:label "d3f:Network" .
d3f:Action rdfs:label "d3f:Action" .

s223:cnx rdfs:label "s223:cnx" .
s223:Controller rdfs:label "s223:Controller" .
s223:Sensor rdfs:label "s223:Sensor" .
s223:Actuator rdfs:label "s223:Actuator" .


:AuditLogShape rdf:type owl:NamedIndividual, sh:NodeShape ;
              sh:property [ 
                sh:path :recordsEvent ;
                sh:class :Event ; 
                sh:minCount 1 ;
              ] ;
              sh:property [ 
                sh:path :generatedBy ;
                sh:class :Asset ; 
                sh:minCount 1;
              ] ;
              sh:targetClass :AuditLog .

:AccessRequestShape rdf:type owl:NamedIndividual, sh:NodeShape ;
                    sh:property [
                      sh:path :requestsAccessTo ;
                      sh:class :Asset ;
                      sh:minCount 1 ;
                    ] ;
                    sh:property [
                      sh:path :authorizedFor ;
                      sh:class :Permission ;
                      sh:minCount 1 ;
                    ] ;
                    sh:property [
                      sh:path :requestedBy ;
                      sh:class d3f:User ; 
                      sh:minCount 1 ;
                    ] ;
                    sh:targetClass :AccessRequest .



###  http://data.ashrae.org/standard223#FunctionShape
:FunctionShape rdf:type owl:NamedIndividual ,
                            sh:NodeShape ;
                   sh:property [ sh:class   s223:Property ;
                                 sh:path :modifies
                               ] ;
                   sh:targetClass s223:Function .

###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/AssetShape
:AssetShape rdf:type owl:NamedIndividual ,
                     sh:NodeShape ;
            sh:property [ sh:class d3f:Network ;
                          sh:path s223:cnx 
                        ] ; 
            sh:targetClass :Asset .


###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/AuthenticationServiceShape
:AuthenticationServiceShape rdf:type owl:NamedIndividual ,
                                     sh:NodeShape ;
                            sh:property [ sh:class d3f:User ;
                                        sh:path d3f:authenticates ;
                                        sh:minCount 1 ;
                                        ] ;
                            sh:property [ sh:class d3f:Credential ;
                                          sh:path :validates;
                                          sh:minCount 1 ;
                                        ] ;
                            sh:property [
                              sh:path [sh:inversePath :hosts ] ;
                              sh:minCount 1 ;      
                                        ] ; 
                            sh:targetClass d3f:AuthenticationService .

:AuthenticationServerShape rdf:type owl:NamedIndividual ,
                                     sh:NodeShape ;
                            sh:property [ sh:class d3f:AuthenticationService ;
                                          sh:path :hosts 
                                        ] ;
                            sh:property [ sh:class :Asset ;
                                          sh:path :protects 
                                        ] ;
                            sh:targetClass d3f:AuthenticationServer .



:EnforcementPointShape rdf:type owl:NamedIndividual ,
                                sh:NodeShape ;
                        sh:property [ sh:class s223:Property ;
                                      sh:path s223:hasProperty 
                                    ] ;
                        sh:property [ sh:path :protects ;
                                      sh:minCount 1 ;
                                      sh:class :Asset ;
                                    ] ;
                        sh:targetClass :EnforcementPoint .         




###  http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/UserShape
:UserShape 
rdf:type owl:NamedIndividual ,
        sh:NodeShape ;
           
        sh:property [
          sh:class :Asset ;
          sh:path :requestsAccessTo ;
        ] ;
        sh:property [ 
          sh:class d3f:Credential ;
          sh:path :hasCredential ;
          sh:minCount 1 ;
        ] ;

        sh:property [sh:class :Device ;
          sh:path :usesDevice ;
        ] ;


          sh:or (
              [sh:class :EmergencyResponder ]
              [sh:class :Operator ]
              [sh:class :Vendor ]
        ) ;
           sh:targetClass d3f:User .

:NetworkShape rdf:type owl:NamedIndividual ,
                    sh:NodeShape ; 
            sh:property [sh:class :Asset ;
                          sh:path :containsAsset
                        ] ;
            sh:targetClass d3f:Network .

:FirewallShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;
               sh:property [sh:class d3f:NetworkTraffic ;
                             sh:path d3f:filters
                           ] ;
               sh:targetClass d3f:Firewall .

:SensorShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;
               sh:property [sh:hasValue :ControlNetwork ;
                             sh:path s223:cnx ;
                           ] ;
               sh:targetClass s223:Sensor .

:ControllerShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;
               sh:property [sh:hasValue :ControlNetwork ;
                             sh:path s223:cnx ;
                           ] ;
               sh:targetClass s223:Controller .

:ActuatorShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;
               sh:property [sh:hasValue :ControlNetwork ;
                             sh:path s223:cnx ;
                           ] ;
               sh:targetClass s223:Actuator .

:DeviceShape rdf:type owl:NamedIndividual ,
                      sh:NodeShape ;
              sh:property [sh:class :NetworkSegment ;
                            sh:path s223:cnx ;
                            sh:minCount 1 ;
                            ] ;
              sh:targetClass :Device .

:OperatorShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ModifySetpoints ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ControlAlarms ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :MonitorBuildingServer ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ViewSensorData ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ModifyAccountDetails ;
                ] ;

                sh:targetClass :Operator .

#MUST HAVE ALL OF THESE...note in documentation

:EmergencyResponderShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;
                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :OverrideDoorLocks ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ControlAlarms ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ViewSensorData ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :EmergencyOverride ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ViewCameraFeeds ;
                ] ;

                sh:targetClass :EmergencyResponder .


:VendorShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ViewCameraFeeds ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ConfigureControllers ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ViewSensorData ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ApplySoftwareUpdates ;
                ] ;

                sh:property [
                  sh:path :hasPermission ;
                  sh:hasValue :ViewLogs ;
                ] ;

                sh:property [
                  sh:path :usesDevice ;
                  sh:node [
                    sh:property [
                      sh:path s223:cnx ;
                      sh:hasValue :DMZNetwork ;
                    ]
                  ]
                ] ;
                sh:targetClass :Vendor . 

:PermissionShape rdf:type owl:NamedIndividual ,
                        sh:NodeShape ;
  sh:property [
    sh:path :enforcedBy ;
    sh:class :EnforcementPoint ;
    sh:minCount 1 ;
  ] ;
  sh:targetClass :Permission .

:CredentialShape rdf:type owl:NamedIndividual, sh:NodeShape ; 
    sh:property [
      sh:path [ sh:inversePath :hasCredential ] ;
      sh:minCount 1 ;
      sh:maxCount 1 ;
    ] ;
    sh:targetclass d3f:Credential .




