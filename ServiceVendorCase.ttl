:MFARequirement
    a s223:Property .

:Laptop
    a :Device ;
    s223:cnx :DMZNetwork .

:RemoteAccessNetwork 
    a :NetworkSegment , d3f:Network .

:ControlNetwork 
    a :NetworkSegment, d3f:Network .

:DanPassword123 
    a d3f:Credential . 

:Skybox 
    a :Asset ;
    s223:cnx :SkyboxNetwork . 

