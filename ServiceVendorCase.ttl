@prefix : <http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/> .
@prefix d3f: <http://d3fend.mitre.org/ontologies/d3fend.owl#> .
@prefix s223: <http://data.ashrae.org/standard223#> .
@base <http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension/> .

<http://www.semanticweb.org/snm49/ontologies/2026/5/cyberExtension> rdf:type owl:Ontology ;
                                                                     owl:imports <http://d3fend.mitre.org/ontologies/d3fend/1.4.0/d3fend.owl> ,
                                                                                 <http://data.ashrae.org/standard223/1.0/model/all> .

:Dan
    a d3f:User, :Vendor ;
    :usesDevice :Laptop;
    :hasCredential :DanPassword123 ; 
    :requestsAccessTo :Skybox ;
    :hasPermission :ApplySoftwareUpdates ;
    :hasPermission :ViewLogs ; 
    :hasPermission :ViewSensorData ;
    :hasPermission :ConfigureControllers ;
    :hasPermission :ViewCameraFeeds .

:Skybox 
    a :Asset . 

:SkyboxMFAService
    a :EnforcementPoint , d3f:AuthenticationService ;
    s223:cnx :ControlNetwork ;
    :protects :Skybox ;
    s223:hasProperty :MFARequirement ;
    :validates :DanPassword123 ;
    d3f:authenticates :Dan .

:MFARequirement
    a s223:Property .

:Laptop
    a :Device ;
    s223:cnx :DMZNetwork .

:RemoteAccessNetwork 
    a :NetworkSegment , d3f:Network .

:ControlNetwork 
    a :NetworkSegment, d3f:Network .

:DanPassword123 
    a d3f:Credential . 

:Skybox 
    a :Asset ;
    s223:cnx :SkyboxNetwork . 

:SkyboxNetwork 
    a d3f:Network .

:BuildingServer
    a d3f:AuthenticationServer ;
    :hosts :MFA ;
    :protects :Skybox ;
    s223:cnx :ControlNetwork .
